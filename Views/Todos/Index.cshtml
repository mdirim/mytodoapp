@model IEnumerable<MyTodoApp.Models.TodoItem>
@{
    ViewData["Title"] = "Görev Listesi";
    var currentFilter = ViewBag.CurrentFilter as string;
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-list-check"></i> Toplam</h5>
                <p class="display-4 mb-0">@ViewBag.TotalCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-hourglass-split"></i> Bekliyor</h5>
                <p class="display-4 mb-0">@ViewBag.PendingCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-check-circle"></i> Tamamlandı</h5>
                <p class="display-4 mb-0">@ViewBag.DoneCount</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-list-task"></i> Görevlerim</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Yeni Görev
    </a>
</div>

<div class="btn-group mb-3" role="group">
    <a asp-action="Index" class="btn btn-outline-secondary @(currentFilter is null ? "active" : "")">
        <i class="bi bi-list"></i> Tümü
    </a>
    <a asp-action="Index" asp-route-filter="pending" class="btn btn-outline-warning @(currentFilter == "pending" ? "active" : "")">
        <i class="bi bi-hourglass-split"></i> Bekleyenler
    </a>
    <a asp-action="Index" asp-route-filter="done" class="btn btn-outline-success @(currentFilter == "done" ? "active" : "")">
        <i class="bi bi-check-circle"></i> Tamamlananlar
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
        <h4 class="mt-3">Henüz görev yok</h4>
        <p>Yeni bir görev ekleyerek başla!</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> İlk Görevi Ekle
        </a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <ul class="list-group list-group-flush">
            @foreach (var item in Model)
            {
                <li class="list-group-item d-flex align-items-center @(item.IsDone ? "bg-light" : "")">
                    <form asp-action="Toggle" asp-route-id="@item.Id" method="post" class="me-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link p-0" title="Tamamlandı olarak işaretle">
                            @if (item.IsDone)
                            {
                                <i class="bi bi-check-circle-fill text-success" style="font-size: 1.5rem;"></i>
                            }
                            else
                            {
                                <i class="bi bi-circle text-secondary" style="font-size: 1.5rem;"></i>
                            }
                        </button>
                    </form>

                    <div class="flex-grow-1">
                        <h5 class="mb-1 @(item.IsDone ? "text-decoration-line-through text-muted" : "")">
                            @item.Title
                        </h5>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="mb-1 text-muted small">@item.Description</p>
                        }
                        <small class="text-muted">
                            <i class="bi bi-calendar3"></i> @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            @if (item.DueDate.HasValue)
                            {
                                <span class="ms-2 badge bg-info">
                                    <i class="bi bi-flag"></i> Son: @item.DueDate.Value.ToLocalTime().ToString("dd.MM.yyyy")
                                </span>
                            }
                        </small>
                    </div>

                    <div class="btn-group">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Detaylar">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Sil">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </li>
            }
        </ul>
    </div>
}
